{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/video-musa.mp4",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" },
        { "key": "Accept-Ranges", "value": "bytes" }
      ]
    }
  ]
}
